# Server
PORT=3001
NODE_ENV=development

# Database
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/getfit

# JWT
# Generate with: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_at_least_32_characters
JWT_EXPIRES_IN=7d

# Application URL (used in email links)
APP_URL=http://localhost:3001

# Email (Gmail App Password recommended)
# Guide: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Admin seed — used by: npm run script:seed-admin
ADMIN_EMAIL=admin@getfit.com
ADMIN_PASSWORD=your_secure_admin_password
ADMIN_NAME=System Admin
